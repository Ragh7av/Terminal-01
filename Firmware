// ========= Helper: encoder & button =========
int readEncoderStep() {
  int encA = digitalRead(ENC_A_PIN);
  int encB = digitalRead(ENC_B_PIN);
  int step = 0;
  if (encA != lastEncA) {
    if (encA == LOW) {
      if (encB == HIGH) step = +1;
      else              step = -1;
    }
  }
  lastEncA = encA;
  lastEncB = encB;
  return step;
}

// Handles Short Press (Select) and Long Press (Back)
void updateEncoderButton() {
  encShortPressed = false;
  encLongPressed = false;
  bool cur = (digitalRead(ENC_BTN_PIN) == LOW);
  unsigned long now = millis();

  if (cur && !btnIsPressed && (now - lastBtnMs > 50)) {
    btnIsPressed = true;
    btnPressStart = now;
    lastBtnMs = now;
  } else if (!cur && btnIsPressed) {
    btnIsPressed = false;
    unsigned long dur = now - btnPressStart;
    if (dur > 500) {
      encLongPressed = true; 
    } else if (dur > 50) {
      encShortPressed = true; 
    }
    lastBtnMs = now;
  }
}

